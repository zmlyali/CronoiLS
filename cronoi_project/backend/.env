# Cronoi LS — Environment Variables
# Bu dosyayı backend/ klasöründe .env olarak kaydet

APP_NAME=Cronoi LS
DEBUG=true
SECRET_KEY=cronoi-dev-secret-key-change-in-production-32chars

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://cronoi_user:cronoi_pass@localhost:5432/cronoi_ls
#DATABASE_URL=postgresql+asyncpg://cronoi_user:3412135@localhost:5432
# CORS — HTML dosyanızın açıldığı adres (file:// için null ekleyin)
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:5500","http://localhost:5500","null"]

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Sprint 2'de gerekecek (şimdilik boş bırakın)
REDIS_URL=
CELERY_BROKER_URL=
